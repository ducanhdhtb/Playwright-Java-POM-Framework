<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<!-- Parallel suite. Use with: mvn test -Dtestng.suiteXmlFile=testng-parallel.xml -->
<suite name="Playwright Suite (Parallel)" verbose="1" parallel="classes" thread-count="4">
  <listeners>
    <listener class-name="utils.TestListener"/>
    <listener class-name="utils.RetryTransformer"/>
  </listeners>
  <test name="All Tests (Parallel)">
    <packages>
      <package name="automation_exercise.tests.ui"/>
      <package name="automation_exercise.tests.api"/>
    </packages>
  </test>
</suite>
