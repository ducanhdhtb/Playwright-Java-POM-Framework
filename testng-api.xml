<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<!-- API-only suite (no browser). Use with: mvn test -Dtestng.suiteXmlFile=testng-api.xml -->
<suite name="API Test Suite" verbose="1" parallel="classes" thread-count="3">
  <listeners>
    <listener class-name="utils.TestListener"/>
    <listener class-name="utils.RetryTransformer"/>
  </listeners>
  <test name="API Tests">
    <groups>
      <run>
        <include name="api"/>
      </run>
    </groups>
    <packages>
      <package name="automation_exercise.tests.api"/>
    </packages>
  </test>
</suite>
