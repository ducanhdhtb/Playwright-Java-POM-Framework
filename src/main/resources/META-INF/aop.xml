<!DOCTYPE aspectj PUBLIC
        "-//AspectJ//DTD//EN" "http://www.eclipse.org/aspectj/dtd/aspectj.dtd">
<aspectj>
    <weaver>
        <!-- Enable weaving for test code + Page Objects so Allure @Step works. -->
        <include within="utils..*"/>
        <include within="pages..*"/>
        <include within="automation_exercise..*"/>
        <!-- Avoid weaving TestNG test classes; it can trigger duplicate AjcClosure definitions in surefire. -->
        <exclude within="automation_exercise.tests..*"/>
    </weaver>
    <aspects>
        <!-- Specify the exact aspect class to be used -->
        <aspect name="utils.StepLoggerAspect"/>
    </aspects>
</aspectj>
