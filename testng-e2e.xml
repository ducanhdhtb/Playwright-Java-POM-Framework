<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<!-- E2E suite. Use with: mvn test -Dtestng.suiteXmlFile=testng-e2e.xml -->
<suite name="E2E Suite" verbose="1" parallel="none" thread-count="1">
  <listeners>
    <listener class-name="utils.TestListener"/>
    <listener class-name="utils.RetryTransformer"/>
  </listeners>

  <test name="E2E">
    <groups>
      <run>
        <include name="e2e"/>
      </run>
    </groups>
    <packages>
      <package name="automation_exercise.tests.ui"/>
    </packages>
  </test>
</suite>

